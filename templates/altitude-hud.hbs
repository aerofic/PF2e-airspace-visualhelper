<section class="airspace-panel" aria-label="{{localize 'PF2E_FLYING_VISUAL_HELPER.Hud.title'}}">
  <header class="airspace-toolbar">
    <div class="airspace-heading">
      <i class="fa-solid fa-wind" aria-hidden="true"></i>
      <span>{{localize "PF2E_FLYING_VISUAL_HELPER.Hud.airspace"}}</span>
    </div>
    <nav class="airspace-filters" aria-label="{{localize 'PF2E_FLYING_VISUAL_HELPER.Hud.filtersLabel'}}">
      {{#each filters}}
        <button
          id="pf2e-fvh-filter-{{id}}"
          type="button"
          class="airspace-filter {{#if active}}active{{/if}}"
          data-action="setFilter"
          data-filter="{{id}}"
          aria-pressed="{{active}}"
        >{{label}}</button>
      {{/each}}
    </nav>
  </header>

  {{#if selected}}
    <section class="airspace-relations" aria-label="{{localize 'PF2E_FLYING_VISUAL_HELPER.Hud.relationsTitle'}}">
      <div class="airspace-relations-heading">
        <span>{{localize "PF2E_FLYING_VISUAL_HELPER.Hud.relationsTitle"}}</span>
        <strong>{{selected.name}} &middot; {{selected.elevationLabel}}</strong>
      </div>
      {{#if hasRelations}}
        <ul>
          {{#each relations}}
            <li>
              <button
                id="pf2e-fvh-relation-{{id}}"
                type="button"
                data-action="focusToken"
                data-token-id="{{id}}"
                data-tooltip="{{tooltipText}}"
                data-tooltip-direction="RIGHT"
                aria-label="{{relationActionLabel}}"
              >
                <span>{{name}}</span>
                <strong>{{relationText}}</strong>
              </button>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p class="airspace-empty-relation">
          {{noNearbyAirText}}
        </p>
      {{/if}}
    </section>
  {{/if}}

  {{#if hasTokens}}
    {{#if enableHeightAxis}}
      <div
        class="airspace-axis-scroll"
        role="region"
        tabindex="0"
        aria-label="{{localize 'PF2E_FLYING_VISUAL_HELPER.Hud.axisLabel'}}"
      >
        <div class="airspace-axis" style="height: {{axis.height}}px; min-width: {{axis.width}}px;">
          <div class="airspace-axis-rail" aria-hidden="true"></div>
          {{#each axis.ticks}}
            <div
              class="airspace-tick {{#if major}}major{{/if}}"
              style="--airspace-y: {{y}}px;"
              aria-hidden="true"
            >
              <span>{{label}}</span>
            </div>
          {{/each}}

          {{#each axis.nodes}}
            <button
              id="pf2e-fvh-axis-token-{{id}}"
              type="button"
              class="airspace-token-node"
              style="--airspace-y: {{axisY}}px; --airspace-lane: {{lane}};"
              data-action="focusToken"
              data-token-id="{{id}}"
              data-tooltip="{{tooltipText}}"
              data-tooltip-direction="RIGHT"
              aria-label="{{accessibleLabel}}"
            >
              <img src="{{img}}" alt="" loading="lazy">
              <span class="airspace-node-height">{{elevationLabel}}</span>
              <span class="airspace-node-name">{{name}}</span>
            </button>
          {{/each}}
        </div>
      </div>
    {{else}}
      <ul class="airspace-compact-list">
        {{#each entries}}
          <li>
            <button
              id="pf2e-fvh-list-token-{{id}}"
              type="button"
              class="airspace-compact-token"
              data-action="focusToken"
              data-token-id="{{id}}"
              data-tooltip="{{tooltipText}}"
              data-tooltip-direction="RIGHT"
              aria-label="{{accessibleLabel}}"
            >
              <img src="{{img}}" alt="" loading="lazy">
              <strong>{{elevationLabel}}</strong>
              <span>{{name}}</span>
            </button>
          </li>
        {{/each}}
      </ul>
    {{/if}}
  {{else}}
    <div class="airspace-empty">
      <i class="fa-regular fa-eye-slash" aria-hidden="true"></i>
      <p>{{localize "PF2E_FLYING_VISUAL_HELPER.Hud.empty"}}</p>
    </div>
  {{/if}}
</section>
